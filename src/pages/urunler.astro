---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import ProductFilters from "../components/products/ProductFilters";

// Local assets
import productsHeroImg from "../assets/products-hero.png";
---

<BaseLayout 
  title="Ürünler Kataloğu"
  description="Eylül Arıcılık bal çeşitleri, propolis özütleri, polen, arı sütü, arı ekmeği ve kaliteli arıcılık ekipmanları ürün kataloğu."
>
  <!-- Page Header -->
  <section class="products-header-section bg-cream">
    <div class="container header-split-grid">
      <div class="header-text-col">
        <SectionHeading
          title="Ürün Kataloğu"
          tagline="Doğal ve Güvenilir"
          description="Ardahan Hanak yaylalarından topladığımız saf arı ürünlerini ve arıcılık ekipmanlarımızı inceleyebilir, bilgi almak için doğrudan bizimle iletişime geçebilirsiniz."
          align="left"
          level="h1"
        />
      </div>
      <div class="header-img-col">
        <div class="header-img-frame">
          <Image src={productsHeroImg} alt="Eylül Arıcılık Ürün Kataloğu Arıcılık Aletleri ve Ballar" class="header-hero-img" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <!-- Catalog Workspace Section -->
  <section class="catalog-workspace-section">
    <div class="container">
      {/* Load the interactive React filter component client-side */}
      <ProductFilters client:load />
    </div>
  </section>
</BaseLayout>

<style>
  .header-split-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    align-items: center;
  }

  @media (min-width: 768px) {
    .header-split-grid {
      grid-template-columns: 1.2fr 0.8fr;
      gap: var(--space-6);
    }
  }

  .header-img-frame {
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    border: 1px solid rgba(92, 58, 33, 0.1);
  }

  .header-hero-img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16/10;
    object-fit: cover;
  }

  .products-header-section {
    padding-top: var(--space-5);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid rgba(92, 58, 33, 0.05);
  }

  .catalog-workspace-section {
    padding-top: var(--space-6);
    padding-bottom: var(--space-8);
    background-color: var(--color-white);
  }
</style>
