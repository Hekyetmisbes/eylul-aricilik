---
import { siteConfig } from "../config/site";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import CookieNotice from "../components/ui/CookieNotice";
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  breadcrumbs?: Array<{ label: string; href: string }>;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { 
  title, 
  description = siteConfig.description,
  canonicalUrl = new URL(Astro.url.pathname, siteConfig.url).href,
  breadcrumbs = [],
  structuredData
} = Astro.props;

const pageTitle = title ? `${title} | ${siteConfig.name}` : `${siteConfig.name} - ${siteConfig.tagline}`;
const socialImageUrl = new URL(siteConfig.ogImageUrl, siteConfig.url).href;
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "Store"],
  "@id": `${siteConfig.url}/#business`,
  name: siteConfig.name,
  url: siteConfig.url,
  logo: new URL(siteConfig.logoUrl, siteConfig.url).href,
  image: socialImageUrl,
  description: siteConfig.description,
  telephone: siteConfig.phone.replace(/\s+/g, ""),
  email: siteConfig.email,
  address: {
    "@type": "PostalAddress",
    streetAddress: "Selamverdi Mah. Atatürk Cad.",
    addressLocality: siteConfig.district,
    addressRegion: siteConfig.city,
    postalCode: "75600",
    addressCountry: "TR"
  },
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
    opens: "08:00",
    closes: "20:00"
  },
  sameAs: Object.values(siteConfig.socials)
};
const websiteSchema = Astro.url.pathname === "/" ? {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteConfig.url}/#website`,
  url: siteConfig.url,
  name: siteConfig.name,
  inLanguage: "tr-TR",
  publisher: { "@id": `${siteConfig.url}/#business` }
} : undefined;
const breadcrumbSchema = breadcrumbs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Ana Sayfa", item: siteConfig.url },
    ...breadcrumbs.map((item, index) => ({
      "@type": "ListItem",
      position: index + 2,
      name: item.label,
      item: new URL(item.href, siteConfig.url).href
    }))
  ]
} : undefined;
const pageStructuredData = structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : [];
---

<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO Primary Meta Tags -->
    <title>{pageTitle}</title>
    <meta name="title" content={pageTitle} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:locale" content="tr_TR" />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content="Eylül Arıcılık - Hanak, Ardahan" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />

    <!-- Google Fonts - Inter and Manrope -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@500;600;700;800&family=Merriweather:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    
    <!-- Robots and Sitemap -->
    <meta name="robots" content="index, follow" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(localBusinessSchema)} />
    {websiteSchema && <script type="application/ld+json" is:inline set:html={JSON.stringify(websiteSchema)} />}
    {breadcrumbSchema && <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />}
    {pageStructuredData.map((schema) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    <!-- Skip to Content for Screen Readers -->
    <a href="#main-content" class="skip-to-content">Ana İçeriğe Geç</a>

    <Header />
    
    <!-- Main content container -->
    <main id="main-content">
      <slot />
    </main>

    <Footer />

    <!-- Cookie Notice Island -->
    <CookieNotice client:load />

    <!-- Back to Top Button -->
    <button id="back-to-top" class="back-to-top-btn" aria-label="Yukarı Git" title="Yukarı Git">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </button>

    <script>
      // Soft animations on scroll using Intersection Observer
      const observerOptions = {
        root: null,
        rootMargin: '0px',
        threshold: 0.1
      };

      const scrollObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animate-in');
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);

      document.querySelectorAll('.scroll-fade').forEach(el => {
        scrollObserver.observe(el);
      });

      // Back to Top Button Logic
      const backToTopBtn = document.getElementById('back-to-top');
      if (backToTopBtn) {
        window.addEventListener('scroll', () => {
          if (window.scrollY > 300) {
            backToTopBtn.classList.add('visible');
          } else {
            backToTopBtn.classList.remove('visible');
          }
        });

        backToTopBtn.addEventListener('click', () => {
          window.scrollTo({
            top: 0,
            behavior: 'smooth'
          });
        });
      }
    </script>
    
    <style is:global>
      /* Simple CSS transition classes for scroll animation */
      .scroll-fade {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .scroll-fade.animate-in {
        opacity: 1;
        transform: translateY(0);
      }

      /* Back to top button styling */
      .back-to-top-btn {
        position: fixed;
        bottom: var(--space-5);
        right: var(--space-5);
        width: 46px;
        height: 46px;
        border-radius: var(--radius-pill);
        background-color: var(--color-honey-500);
        color: var(--color-black-soft);
        border: 1px solid var(--color-honey-600);
        box-shadow: 0 4px 16px rgba(46, 27, 16, 0.15);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 99;
        opacity: 0;
        visibility: hidden;
        transform: translateY(10px);
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .back-to-top-btn.visible {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
      }

      .back-to-top-btn:hover {
        background-color: var(--color-honey-600);
        box-shadow: 0 6px 20px rgba(46, 27, 16, 0.25);
        transform: translateY(-2px);
      }

      .back-to-top-btn:active {
        transform: translateY(0);
      }
    </style>
  </body>
</html>
