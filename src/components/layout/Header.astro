---
import { Image } from "astro:assets";
import { siteConfig } from "../../config/site";
import logoImg from "../../assets/logo.png";

const currentPath = Astro.url.pathname;
const isHome = currentPath === "/";
---

<header id="site-header" class="site-header">
  <div class="container header-container">
    <!-- Logo -->
    <a href="/" class="logo-link" aria-label="Eylül Arıcılık Ana Sayfa">
      <Image src={logoImg} alt="Eylül Arıcılık Logo" class="brand-logo" loading="eager" />
    </a>

    <!-- Desktop Navigation -->
    <nav class="desktop-nav" aria-label="Ana Menü">
      <ul class="nav-list">
        {siteConfig.navigation.map((item) => {
          const isActive = currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href));
          return (
            <li>
              <a 
                href={item.href} 
                class={`nav-link ${isActive ? "active" : ""}`}
                aria-current={isActive ? "page" : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <!-- Header Actions (Desktop) -->
    <div class="header-actions">


      <!-- WhatsApp Shortcut -->
      <a href={siteConfig.whatsappUrl} target="_blank" rel="noopener noreferrer" class="action-icon-btn whatsapp-btn" aria-label="WhatsApp ile Sor">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
        </svg>
      </a>

      <!-- CTA Button -->
      <a href="/iletisim" class="cta-button-header">Bize Ulaşın</a>
    </div>

    <!-- Mobile Header Actions (Menu Toggle) -->
    <div class="mobile-actions">
      <button id="menu-toggle" class="menu-toggle" aria-expanded="false" aria-controls="mobile-drawer" aria-label="Menüyü Aç">
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Drawer -->
  <div id="mobile-drawer" class="mobile-drawer" aria-hidden="true">
    <div class="drawer-content">
      <div class="drawer-header">
        <div class="logo-wrapper">
          <Image src={logoImg} alt="Eylül Arıcılık Logo" class="brand-logo mobile-logo" loading="eager" />
        </div>
        <button id="menu-close" class="menu-close" aria-label="Menüyü Kapat">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>

      <nav class="mobile-nav" aria-label="Mobil Menü">
        <ul class="mobile-nav-list">
          {siteConfig.navigation.map((item) => {
            const isActive = currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href));
            return (
              <li>
                <a 
                  href={item.href} 
                  class={`mobile-nav-link ${isActive ? "active" : ""}`}
                  aria-current={isActive ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>

      <div class="drawer-footer">
        <a href={siteConfig.whatsappUrl} target="_blank" rel="noopener noreferrer" class="mobile-drawer-cta whatsapp">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="btn-icon">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
          </svg>
          WhatsApp ile Ulaşın
        </a>
        <a href="/iletisim" class="mobile-drawer-cta primary">
          Bize Ulaşın
        </a>
        <div class="drawer-contact-info">
          <p class="drawer-phone">{siteConfig.phoneFormatted}</p>
          <p class="drawer-email">{siteConfig.email}</p>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById("site-header");
  const menuToggle = document.getElementById("menu-toggle");
  const menuClose = document.getElementById("menu-close");
  const mobileDrawer = document.getElementById("mobile-drawer");
  
  // Sticky header background and shadow on scroll
  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      header?.classList.add("scrolled");
    } else {
      header?.classList.remove("scrolled");
    }
  });

  // Toggle mobile drawer
  function openMenu() {
    menuToggle?.setAttribute("aria-expanded", "true");
    mobileDrawer?.setAttribute("aria-hidden", "false");
    mobileDrawer?.classList.add("open");
    document.body.style.overflow = "hidden"; // Prevent scrolling behind drawer
  }

  function closeMenu() {
    menuToggle?.setAttribute("aria-expanded", "false");
    mobileDrawer?.setAttribute("aria-hidden", "true");
    mobileDrawer?.classList.remove("open");
    document.body.style.overflow = "";
  }

  menuToggle?.addEventListener("click", openMenu);
  menuClose?.addEventListener("click", closeMenu);

  // Close drawer if screen resized above mobile breakpoint
  window.addEventListener("resize", () => {
    if (window.innerWidth >= 1024) {
      closeMenu();
    }
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    left: 0;
    right: 0;
    height: 80px;
    background-color: var(--color-cream);
    z-index: 50;
    border-bottom: 1px solid rgba(92, 58, 33, 0.05);
    display: flex;
    align-items: center;
    transition: background-color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .site-header.scrolled {
    background-color: var(--color-white);
    border-color: rgba(92, 58, 33, 0.1);
    box-shadow: var(--shadow-header);
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  /* Logo */
  .logo-link {
    display: block;
    color: var(--color-brown-900);
  }

  .brand-logo {
    height: 48px;
    width: auto;
    object-fit: contain;
    display: block;
    transition: transform 0.3s ease;
  }

  .logo-link:hover .brand-logo {
    transform: scale(1.05);
  }

  .mobile-logo {
    height: 40px;
  }

  .brand-title {
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: 2px;
    font-family: "Manrope", sans-serif;
  }

  .brand-subtitle {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 4px;
    color: var(--color-brown-500);
  }

  /* Desktop Navigation */
  .desktop-nav {
    display: none;
  }

  .nav-list {
    list-style: none;
    display: flex;
    gap: var(--space-5);
  }

  .nav-link {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-brown-700);
    padding: var(--space-2) 0;
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-honey-500);
    transition: width 0.3s ease;
  }

  .nav-link:hover {
    color: var(--color-honey-600);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  .nav-link.active {
    color: var(--color-honey-700);
  }

  /* Actions */
  .header-actions {
    display: none;
    align-items: center;
    gap: var(--space-4);
  }

  .action-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-pill);
    color: var(--color-brown-700);
    background-color: transparent;
    border: none;
    cursor: pointer;
  }

  .action-icon-btn:hover {
    color: var(--color-honey-600);
    background-color: rgba(245, 197, 66, 0.1);
  }

  .whatsapp-btn:hover {
    color: #25d366;
    background-color: rgba(37, 211, 102, 0.1);
  }

  .cta-button-header {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-honey-500);
    color: var(--color-black-soft);
    font-weight: 600;
    height: 44px;
    padding-inline: var(--space-5);
    border-radius: 10px;
    font-size: 0.95rem;
    box-shadow: 0 4px 12px rgba(245, 197, 66, 0.15);
  }

  .cta-button-header:hover {
    background-color: var(--color-honey-600);
    box-shadow: 0 6px 16px rgba(245, 197, 66, 0.25);
    transform: translateY(-1px);
  }

  /* Mobile Actions */
  .mobile-actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 12px;
    border-radius: var(--radius-pill);
  }

  .menu-toggle:hover {
    background-color: rgba(92, 58, 33, 0.05);
  }

  .hamburger-bar {
    width: 20px;
    height: 2px;
    background-color: var(--color-brown-700);
    border-radius: 2px;
    transition: all 0.2s ease;
  }

  /* Mobile Drawer */
  .mobile-drawer {
    position: fixed;
    top: 0;
    right: -100%;
    width: 100%;
    max-width: 400px;
    height: 100vh;
    background-color: var(--color-white);
    z-index: 100;
    box-shadow: -10px 0 30px rgba(0,0,0,0.05);
    transition: right 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    visibility: hidden;
  }

  .mobile-drawer.open {
    right: 0;
    visibility: visible;
  }

  .drawer-content {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: var(--space-5);
  }

  .drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-6);
  }

  .menu-close {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-pill);
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    color: var(--color-brown-700);
    cursor: pointer;
  }

  .menu-close:hover {
    background-color: rgba(92, 58, 33, 0.05);
    color: var(--color-error);
  }

  .mobile-nav {
    flex-grow: 1;
  }

  .mobile-nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .mobile-nav-link {
    display: block;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-brown-900);
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-gray-100);
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.active {
    color: var(--color-honey-600);
    padding-left: var(--space-2);
  }

  .drawer-footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: auto;
    border-top: 1px solid var(--color-gray-300);
    padding-top: var(--space-5);
  }

  .mobile-drawer-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 48px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 1rem;
    gap: var(--space-2);
  }

  .mobile-drawer-cta.whatsapp {
    background-color: transparent;
    color: #25d366;
    border: 1px solid #25d366;
  }

  .mobile-drawer-cta.whatsapp:hover {
    background-color: rgba(37, 211, 102, 0.05);
  }

  .mobile-drawer-cta.primary {
    background-color: var(--color-honey-500);
    color: var(--color-black-soft);
  }

  .mobile-drawer-cta.primary:hover {
    background-color: var(--color-honey-600);
  }

  .drawer-contact-info {
    text-align: center;
    margin-top: var(--space-3);
  }

  .drawer-phone {
    font-weight: 700;
    color: var(--color-brown-900);
    font-size: 1.1rem;
  }

  .drawer-email {
    font-size: 0.875rem;
    color: var(--color-gray-500);
  }

  .btn-icon {
    flex-shrink: 0;
  }

  /* Responsive breakpoints */
  @media (min-width: 1024px) {
    .desktop-nav {
      display: block;
    }
    .header-actions {
      display: flex;
    }
    .mobile-actions {
      display: none;
    }
  }
</style>
